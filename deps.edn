{:paths ["src" "resources"]
 :deps {org.clojure/clojure       {:mvn/version "1.12.3"}
         org.clojure/tools.cli     {:mvn/version "1.1.230"}
         org.clojure/core.async    {:mvn/version "1.6.681"}
         org.clojure/data.csv      {:mvn/version "1.1.0"}
         camel-snake-kebab/camel-snake-kebab {:mvn/version "0.4.3"}
         ;; Reitit routing and OpenAPI support
         metosin/reitit            {:mvn/version "0.10.1"}
         fi.metosin/reitit-openapi {:mvn/version "0.10.1"}
         metosin/reitit-swagger-ui {:mvn/version "0.10.1"}
         metosin/reitit-malli      {:mvn/version "0.10.1"}
         metosin/malli             {:mvn/version "0.20.1"}
         metosin/muuntaja          {:mvn/version "0.6.11"}
         ;; Web server and utilities
         ring/ring-jetty-adapter   {:mvn/version "1.10.0"}
         ring/ring-mock            {:mvn/version "0.6.2"}
         cheshire/cheshire         {:mvn/version "5.13.0"}
         clj-http/clj-http         {:mvn/version "3.13.0"}
         com.taoensso/timbre       {:mvn/version "6.0.4"}
         integrant/integrant       {:mvn/version "0.8.1"}
         aero/aero                 {:mvn/version "1.1.6"}
         tick/tick                 {:mvn/version "0.7.5"}
         com.cemerick/url          {:mvn/version "0.1.1"}
         migratus/migratus         {:mvn/version "1.6.3"}
         org.postgresql/postgresql {:mvn/version "42.6.0"}
         com.github.seancorfield/next.jdbc {:mvn/version "1.3.1070"}
         com.github.seancorfield/honeysql  {:mvn/version "2.6.1126"}
}
 :aliases {:run {:main-opts ["-m" "tunarr.scheduler.main"]}
            :test {:extra-paths ["test"]
                   :extra-deps {eftest/eftest {:mvn/version "0.6.0"}
                                ring/ring-mock {:mvn/version "0.4.0"}
                                com.h2database/h2 {:mvn/version "2.2.220"}}
                   ;; Run the suite sequentially: several test namespaces
                   ;; blanket-`with-redefs` clj-http.client/post and
                   ;; tunabrain/http/post, and eftest's namespace-level
                   ;; parallelism still leaks those redefs across namesapces
                   ;; (see G.12/G.13 in the cluster report). Until those tests
                   ;; move to component injection, disable multithreading
                   ;; entirely so the test failure surfaces are real rather
                   ;; than cross-test interleaving artefacts.
                   :main-opts ["-e" "(require '[eftest.runner :refer [find-tests run-tests]]) (run-tests (find-tests \"test\") {:multithread? false})"]}
           :migrate {:exec-fn app.migrate/run
                     :exec-args {}}}}
