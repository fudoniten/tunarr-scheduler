{:log-level #or [#env LOG_LEVEL :debug]
 :server {:port #or [#env PORT 8080]}
 :pseudovision {:base-url #or [#env PSEUDOVISION_URL "http://localhost:8080"]
                :auto-sync #or [#env PSEUDOVISION_AUTO_SYNC true]
                ;; Map tunarr-scheduler library names to Pseudovision collection IDs
                ;; This is optional - if not specified, will create new collections
                :library-mappings {}}
 :jellyfin {:base-url #or [#env JELLYFIN_URL "http://localhost:8096"]
            :api-key #or [#env JELLYFIN_API_KEY "change-me"]
            :library-ids []}
 :llm {:provider #or [#env LLM_PROVIDER :mock]
       :model #or [#env LLM_MODEL "gpt-4o"]
       :endpoint #or [#env LLM_ENDPOINT "https://api.openai.com/v1"]
       :api-key #or [#env LLM_API_KEY nil]}
 :tts {:provider #or [#env TTS_PROVIDER :mock]
       :voice #or [#env TTS_VOICE "default"]}
 :tunabrain {:endpoint #or [#env TUNABRAIN_ENDPOINT "http://localhost:8080"]
             :http-opts {:socket-timeout 120000
                         :connection-timeout 10000}}
  :scheduler {:enabled #or [#env SCHEDULER_ENABLED false]
               :time-zone #or [#env TIME_ZONE "UTC"]
               :check-interval #or [#env SCHEDULER_CHECK_INTERVAL 60]
               :daily-hour #or [#env SCHEDULER_DAILY_HOUR 3]
               :weekly-day #or [#env SCHEDULER_WEEKLY_DAY 1]
               :weekly-hour #or [#env SCHEDULER_WEEKLY_HOUR 4]
               :monthly-day #or [#env SCHEDULER_MONTHLY_DAY 1]
               :monthly-hour #or [#env SCHEDULER_MONTHLY_HOUR 5]
               :quarterly-hour #or [#env SCHEDULER_QUARTERLY_HOUR 6]
               :daytime-hours {:start 6 :end 20}
               :seasonal {:december [:holiday]
                          :october [:spooky]}
               :preferences {}}
 :categories {:time-slot {:description "Best time of day to air this content"
                          :values [:daytime :primetime :late-night]}
              :audience {:description "Primary target audience"
                         :values [:kids :family :teen :adult]}
              :season {:description "Best season or time of year to air"
                       :values [:any :spring :summer :fall :winter
                                :holiday :halloween :valentines :independence]}
              :freshness {:description "Era or vintage of content"
                          :values [:classic :retro :modern :contemporary]}}
 ;; Future category expansion possibilities (not yet implemented):
 ;; :engagement {:description "Required viewer attention and content intensity"
 ;;              :values [:background :casual :focused :immersive]}
 ;; :duration-category {:description "Content length for scheduling blocks"
 ;;                     :values [:short :standard :feature :long]}
 ;; :day-preference {:description "Preferred day of week"
 ;;                  :values [:weekday :weekend :any]}
 :persistence {:type :memory
                :path #or [#env STATE_PATH "data/state.edn"]}}
